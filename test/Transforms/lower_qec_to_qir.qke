// RUN: cudaq-opt --convert-to-qir-api %s | FileCheck %s

// Verify that qec.detector and qec.logical_observable are lowered to QEC
// runtime calls during QIR conversion (no separate pass needed).

// --- Test 1: Detector with individual !quake.measure operands ---------------

func.func @basic_detector(%r0 : !quake.measure, %r1 : !quake.measure) attributes {"cudaq-kernel"} {
  qec.detector(%r0, %r1) : (!quake.measure, !quake.measure)
  qec.logical_observable(%r0) : (!quake.measure)
  return
}

// CHECK-LABEL: func.func @basic_detector(
// CHECK-SAME:    %[[R0:.*]]: !cc.ptr<!llvm.struct<"Result", opaque>>,
// CHECK-SAME:    %[[R1:.*]]: !cc.ptr<!llvm.struct<"Result", opaque>>)
// CHECK: cc.alloca
// CHECK: cc.store
// CHECK: cc.store
// CHECK: call @__quantum__qis__detector_from_results
// CHECK: cc.alloca
// CHECK: cc.store
// CHECK: call @__quantum__qis__logical_observable_from_results

// --- Test 2: Observable with explicit index ---------------------------------

func.func @observable_with_index(%r0 : !quake.measure, %r1 : !quake.measure) attributes {"cudaq-kernel"} {
  qec.logical_observable(%r0) index 0 : (!quake.measure)
  qec.logical_observable(%r1) index 1 : (!quake.measure)
  return
}

// CHECK-LABEL: func.func @observable_with_index(
// CHECK: call @__quantum__qis__logical_observable_from_results
// CHECK: call @__quantum__qis__logical_observable_from_results

// --- Test 3: Detector with !quake.measurements (Array*) operand -------------

func.func @detector_with_array(%ms : !quake.measurements<?>) attributes {"cudaq-kernel"} {
  qec.detector(%ms) : (!quake.measurements<?>)
  return
}

// CHECK-LABEL: func.func @detector_with_array(
// CHECK-SAME:    %[[ARR:.*]]: !cc.ptr<!llvm.struct<"Array", opaque>>)
// CHECK: call @__quantum__qis__detector_from_array(%[[ARR]])

// --- Test 4: detectors_vectorized with !quake.measurements operands ---------

func.func @vectorized_detectors(%prev : !quake.measurements<?>, %curr : !quake.measurements<?>) attributes {"cudaq-kernel"} {
  qec.detectors_vectorized(%prev, %curr) : (!quake.measurements<?>, !quake.measurements<?>)
  return
}

// CHECK-LABEL: func.func @vectorized_detectors(
// CHECK: call @__quantum__qis__detectors_vectorized_from_arrays
